{
	"name": "@liiift-studio/sanity-order-schema",
	"version": "1.0.0",
	"description": "Shared Sanity order schema for Liiift Studio typeface foundries — internal use only.",
	"private": true,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Liiift-Studio/sanity-tools.git"
	},
	"main": "./dist/index.js",
