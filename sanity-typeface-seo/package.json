{
  "name": "sanity-typeface-seo",
  "version": "1.0.0",
  "description": "Standalone Sanity SEO field definitions for typeface documents — shared social/SEO object across foundries",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sanity",
    "sanity-studio",
    "typeface",
    "schema",
    "seo",
    "foundry"
  ],
  "author": "Quinn Keaveney <quinn@liiift.studio>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Liiift-Studio/sanity-tools.git"
  },
  "peerDependencies": {
    "sanity": ">=3"
  },
  "devDependencies": {
    "sanity": "^3.99.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
