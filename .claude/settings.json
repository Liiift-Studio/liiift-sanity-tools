{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch(*)",
      "WebSearch(*)",
      "Agent(*)",
      "Skill(*)",
      "Skill(*:*)",
      "NotebookEdit(*)",
      "Bash(git rm:*)",
      "Bash(npm info:*)",
      "Bash(git pull:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git reset --hard *)",
      "Bash(git push --force *)",
      "Bash(git push * --force *)",
      "Bash(git clean -f *)",
      "Bash(git checkout -- .)",
      "Bash(git branch -D *)",
      "Bash(> /dev/*)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(kill -9 *)",
      "Bash(shutdown *)",
      "Bash(reboot *)"
    ],
  }
}
